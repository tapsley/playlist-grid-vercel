// Prisma schema for Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  notes     Note[]   @relation("UserNotes")
}

model Note {
  id        String   @id @default(uuid())
  user      User     @relation("UserNotes", fields: [userId], references: [id])
  userId    String
  date      DateTime
  title     String?
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model Video {
  id          String   @id @default(cuid())
  name        String
  title       String?
  description String?
  tags        String[] @default([])
  game        String?
  contentType String?
  size        Int?
  updatedAt   DateTime?
  gcsPath     String   @unique
  url         String
  createdAt   DateTime @default(now())
  indexedAt   DateTime @updatedAt

  @@index([game])
  @@index([name])
  @@index([title])
  @@index([updatedAt])
}