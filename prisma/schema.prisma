model PicrossProgress {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime
  easy      Json     // 5x5 array of numbers (progress)
  medium    Json     // 10x10 array of numbers (progress)
  hard      Json     // 15x15 array of numbers (progress)
  easySeconds   Int     @default(0)
  mediumSeconds Int     @default(0)
  hardSeconds   Int     @default(0)
  easyComplete   Boolean @default(false)
  mediumComplete Boolean @default(false)
  hardComplete   Boolean @default(false)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
  @@index([updatedAt])
}

model PicrossStats {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String   @unique
  fastestEasy   Int?
  fastestMedium Int?
  fastestHard   Int?
  solvedEasy    Int     @default(0)
  solvedMedium  Int     @default(0)
  solvedHard    Int     @default(0)
  currentStreakEasy    Int      @default(0)
  maxStreakEasy        Int      @default(0)
  lastSolvedEasy       DateTime?
  currentStreakMedium  Int      @default(0)
  maxStreakMedium      Int      @default(0)
  lastSolvedMedium     DateTime?
  currentStreakHard    Int      @default(0)
  maxStreakHard        Int      @default(0)
  lastSolvedHard       DateTime?
  goldMedalsEasy     Int @default(0)
  goldMedalsMedium   Int @default(0)
  goldMedalsHard     Int @default(0)
  silverMedalsEasy   Int @default(0)
  silverMedalsMedium Int @default(0)
  silverMedalsHard   Int @default(0)
  updatedAt    DateTime @updatedAt
}

model PicrossMedal {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  date       DateTime
  difficulty String
  type       String
  seconds    Int
  createdAt  DateTime @default(now())

  @@unique([userId, date, difficulty])
  @@index([userId])
  @@index([date])
  @@index([type, difficulty, date])
}
model PicrossPuzzle {
  id         String   @id @default(uuid())
  date       DateTime @unique
  easy       Json     // 5x5 array of booleans (the puzzle)
  medium     Json   // 10x10 array of booleans (the puzzle)
  hard       Json     // 15x15 array of booleans (the puzzle)
  createdAt  DateTime @default(now())
}
// Prisma schema for Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  settings  Json?
  createdAt DateTime @default(now())
  notes     Note[]   @relation("UserNotes")
  picrossProgresses PicrossProgress[]
  picrossStats PicrossStats?
  picrossMedals PicrossMedal[]
}

model Note {
  id        String   @id @default(uuid())
  user      User     @relation("UserNotes", fields: [userId], references: [id])
  userId    String
  date      DateTime
  title     String?
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model Video {
  id          String   @id @default(cuid())
  name        String
  title       String?
  description String?
  tags        String[] @default([])
  game        String?
  contentType String?
  size        Int?
  updatedAt   DateTime?
  gcsPath     String   @unique
  url         String
  thumbnailKey String?
  thumbnailUrl String?
  thumbnailStatus ThumbnailStatus @default(pending)
  thumbnailGeneratedAt DateTime?
  thumbnailError String?
  createdAt   DateTime @default(now())
  indexedAt   DateTime @updatedAt

  @@index([game])
  @@index([name])
  @@index([title])
  @@index([updatedAt])
  @@index([thumbnailStatus])
}

enum ThumbnailStatus {
  pending
  ready
  failed
}
